          "uuid": "1844c387-3df2-43cd-9996-cb1267d09c1c",
          "body": "{{setVar 'order' (queryParam 'order')}}\n{{setVar 'limit' (parseInt (queryParam 'limit'))}}\n{{setVar 'cursor' (queryParam 'after')}}\n\n{{setVar 'data' (sortBy (dataRaw 'pc-logs') 'receivedAt' @order)}}\n\n{{setGlobalVar 'startIndex' -1}}\n{{#each @data}}\n  {{#if (eq this.id @cursor)}}\n    {{setGlobalVar 'startIndex' @index}}\n  {{/if}}\n{{/each}}\n\n{{setVar 'startIndex' (getGlobalVar 'startIndex')}}\n{{setGlobalVar 'startIndex' null}}\n\n{{setVar 'page' (slice @data (add @startIndex 1) (add @startIndex @limit 1))}}\n\n{{setVar 'endIndex' (add @startIndex (len @page))}}\n\n{{setVar 'hasPrev' (gt @startIndex 0)}}\n{{setVar 'hasNext' (lt @endIndex (add (len @data) -1))}}\n\n{\n  \"status\": \"ok\",\n  \"data\": {{{stringify @page}}},\n  \"pagination\": {\n    \"total\": {{len @data}},\n    {{#if @hasPrev}}\n      \"prevCursor\": \"{{@page.0.id}}\",\n    {{/if}}\n    {{#if @hasNext}}\n      \"nextCursor\": \"{{objectPath @page (concat (add (len @page) -1) '.id')}}\",\n    {{/if}}\n    \"hasPrev\": {{@hasPrev}},\n    \"hasNext\": {{@hasNext}}\n  }\n}",

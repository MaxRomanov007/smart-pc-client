          "body": "{{setVar 'order' (queryParam 'order')}}\n{{setVar 'limit' (parseInt (queryParam 'limit'))}}\n\n{{setVar 'data' (sortBy (dataRaw 'pc-logs') 'receivedAt' @order)}}\n\n{{setVar 'page' (slice @data 0 @limit)}}\n\n{{setVar 'hasNext' (gt (len @data) @limit)}}\n\n{\n  \"status\": \"ok\",\n  \"data\": {{{stringify @page}}},\n  \"pagination\": {\n    \"total\": {{len @data}},\n    {{#if @hasNext}}\n      \"nextCursor\": \"{{objectPath @data (concat (add @limit -1) '.id')}}\",\n    {{/if}}\n    \"hasPrev\": false,\n    \"hasNext\": {{@hasNext}}\n  }\n}",

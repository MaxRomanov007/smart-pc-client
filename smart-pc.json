          "uuid": "c612f6f3-4142-4217-98bb-6d7f5011623d",
          "body": "{{setVar 'found' (find (dataRaw 'pcs') (object id=(urlParam 'id')))}}\n\n{{#unless @found}}\n  {\n    \"status\": \"not-found\",\n    \"error\": \"not found\"\n  }\n{{else}}\n\n  {{setVar 'value' (object)}}\n      \n  {{#if (lookup (bodyRaw) 'name')}}\n    {{setVar 'value' (objectMerge @value (object name=(bodyRaw 'name')))}}\n    {{setVar 'value' (objectMerge @value (object slug=(faker 'helpers.slugify' (bodyRaw 'name'))))}}\n  {{/if}}\n  {{#if (lookup (bodyRaw) 'description')}}\n    {{setVar 'value' (objectMerge @value (object description=(bodyRaw 'description')))}}\n  {{/if}}\n  {{#if (gt (len (stringify (body 'canPowerOn'))) 2)}}\n    {{setVar 'value' (objectMerge @value (object canPowerOn=(bodyRaw 'canPowerOn')))}}\n  {{/if}}\n\n  {{setData 'merge' 'pcs' (indexOf (dataRaw 'pcs') @found) @value}}\n  \n  {\n    \"status\": \"ok\",\n    \"data\": {{{stringify (find (dataRaw 'pcs') (object id=(urlParam 'id')))}}}\n  }\n{{/unless}}",
          "latency": 0,

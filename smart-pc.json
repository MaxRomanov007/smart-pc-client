      "value": "[\n  {{setVar 'receivedAt' (date (dateTimeShift hours=-1) (now) \"yyyy-MM-dd'T'HH:mm:ss.SSSxxx\")}}\n  {\n    \"id\": \"log1\",\n    \"commandId\": \"command1\",\n    \"commandName\": \"Success command\",\n    \"receivedAt\": \"{{@receivedAt}}\",\n    \"completedAt\": \"{{dateTimeShift @receivedAt second=(int 1 40)}}\",\n    \"status\": \"ok\"\n  },\n  \n  {{setVar 'receivedAt' (date (dateTimeShift hours=-1) (now) \"yyyy-MM-dd'T'HH:mm:ss.SSSxxx\")}}\n  {\n    \"id\": \"log2\",\n    \"commandId\": \"command2\",\n    \"commandName\": \"Failed command\",\n    \"receivedAt\": \"{{@receivedAt}}\",\n    \"completedAt\": \"{{dateTimeShift @receivedAt second=(int 1 40)}}\",\n    \"status\": \"command-error\",\n    \"error\": \"command not found\"\n  },\n  \n  {{setVar 'receivedAt' (date (dateTimeShift hours=-1) (now) \"yyyy-MM-dd'T'HH:mm:ss.SSSxxx\")}}\n  {\n    \"id\": \"log3\",\n    \"commandId\": \"command3\",\n    \"commandName\": \"Internal error command\",\n    \"receivedAt\": \"{{@receivedAt}}\",\n    \"completedAt\": \"{{dateTimeShift @receivedAt second=(int 1 40)}}\",\n    \"status\": \"internal-error\"\n  },\n  \n  {{setVar 'receivedAt' (date (dateTimeShift hours=-1) (now) \"yyyy-MM-dd'T'HH:mm:ss.SSSxxx\")}}\n  {\n    \"id\": \"log4\",\n    \"commandId\": \"command4\",\n    \"receivedAt\": \"{{@receivedAt}}\",\n    \"completedAt\": \"{{dateTimeShift @receivedAt second=(int 1 40)}}\",\n    \"status\": \"ok\"\n  },\n  \n  {{#repeat 46}}\n    {{setVar 'receivedAt' (date (dateTimeShift hours=-2) (dateTimeShift hours=-1) \"yyyy-MM-dd'T'HH:mm:ss.SSSxxx\")}}\n    {{setVar 'status' (oneOf (array 'ok' 'ok' 'ok' 'ok' 'ok' 'ok' 'ok' 'ok' 'command-error' 'command-error' 'internal-error'))}}\n    {\n      {{#if (oneOf (array true true true true true true true true true false))}}\n        \"commandName\": \"{{faker 'person.jobTitle'}}\",\n      {{/if}}\n      \n      {{#if (eq @status 'command-error')}}\n        \"error\": \"{{faker 'food.description'}}\",\n      {{/if}}\n      \n      \"id\": \"{{uuid}}\",\n      \"commandId\": \"{{uuid}}\",\n      \"receivedAt\": \"{{@receivedAt}}\",\n      \"completedAt\": \"{{dateTimeShift @receivedAt second=(int 1 40)}}\",\n      \"status\": \"{{@status}}\"\n    }\n  {{/repeat}}\n]"
